{
  "version": 2,
  "buildCommand": "npm install --prefix apps/web && npm run build --prefix apps/web",
  "outputDirectory": "apps/web/dist",
  "installCommand": "npm install --legacy-peer-deps && npm install --prefix apps/api --legacy-peer-deps",
  "functions": {
    "api/handler.js": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/handler.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "DATABASE_URL": "@DATABASE_URL",
    "DIRECT_URL": "@DIRECT_URL",
    "NODE_ENV": "@NODE_ENV",
    "PORT": "@PORT",
    "JWT_SECRET": "@JWT_SECRET",
    "ADMIN_SECRET": "@ADMIN_SECRET",
    "AI_SERVICE_URL": "@AI_SERVICE_URL"
  }
}
