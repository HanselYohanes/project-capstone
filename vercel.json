{
  "version": 2,
  "buildCommand": "npm run build --prefix apps/web",
  "outputDirectory": "apps/web/dist",
  "installCommand": "npm install --legacy-peer-deps && npm install --prefix apps/api --legacy-peer-deps && npm install --prefix apps/web --legacy-peer-deps",
  "functions": {
    "api/handler.js": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/handler.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
